# ===========================================
# Observability PoC - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# PostgreSQL (OLTP)
POSTGRES_USER=admin
POSTGRES_PASSWORD=         # Set a strong password
POSTGRES_DB=operations

# ClickHouse (OLAP) - x86_64 only
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=       # Set a strong password

# TimescaleDB (OLAP) - ARM64
TIMESCALE_USER=admin
TIMESCALE_PASSWORD=        # Set a strong password
TIMESCALE_DB=analytics

# Cube.js
CUBEJS_API_SECRET=         # Generate with: openssl rand -hex 32
CUBEJS_DEV_MODE=false      # Set to true ONLY for local development

# Simulator
KAFKA_BROKER=localhost:19092
SIMULATOR_INTERVAL=2000
